# Personal drafts and notes (kept out of the public repo)
doc/

# Trained models and large artifacts (hosted on Hugging Face Hub)
models/
*.pth

# Large data files — keep the small processed splits in git, host big ones on HF Hub.
# (gitignore can't filter by size; check `ls -lh data/processed/` before committing and
#  add any Parquet over ~50 MB here explicitly.)

# Secrets / API keys — NEVER commit these (public repo)
.env
.env.*
!.env.example
*.key
secrets.*

# Python
.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# OS / Office temporary files
.DS_Store
~$*
